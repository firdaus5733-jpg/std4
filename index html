                    { q: "Kaedah pentaksiran...", o: ["Lisan/Tulis/Perhati", "Baca komik", "Ujian bulanan saja", "Wayang"], c: 0, d: "Mudah" },
                    { q: "Maklum balas patut...", o: ["Hina", "Membina", "Bahasa asing", "Lambat"], c: 1, d: "Mudah" },
                    { q: "Semak hasil kerja untuk...", o: ["Isi masa", "Kesan tahap & salah murid", "Tunjuk pengetua", "Buang buku"], c: 1, d: "Mudah" },
                    { q: "Pengayaan untuk murid yang...", o: ["Lemah", "Sudah capai objektif", "Tidur", "Ponteng"], c: 1, d: "Mudah" },
                    { q: "Beza evaluatif & deskriptif?", o: ["Tiada", "Gred vs Cara baiki", "Evaluatif baik", "Deskriptif bahasa saja"], c: 1, d: "Sederhana" },
                    { q: "Cara pemulihan PdP...", o: ["Latihan sama", "Ubah strategi/bahan mudah", "Hukum lambat", "Keluar kelas"], c: 1, d: "Sederhana" },
                    { q: "Peer assessment membantu...", o: ["Cari salah kawan", "Fikir kritis & objektif", "Bercakap", "Meniru"], c: 1, d: "Sederhana" },
                    { q: "Exit Ticket ialah pentaksiran...", o: ["Formatif", "Sumatif", "Diagnostik", "Tiada kaitan"], c: 0, d: "Sukar" },
                    { q: "Data 4.5 digunakan untuk...", o: ["Cari salah", "Rancang tindakan susulan", "Label murid", "Borang cuti"], c: 1, d: "Sukar" }
                ]
            },
            "4.6": {
                title: "Aspek 4.6: Murid Sebagai Pembelajar Aktif",
                description: "Murid terlibat, berkolaborasi, dan mengamalkan nilai murni.",
                standard: "Murid menunjukkan minat dan semangat ingin tahu dalam belajar.",
                notes: [
                    "<strong>Respons:</strong> Menjawab, bertanya, dan memberi pendapat.",
                    "<strong>Kolaborasi:</strong> Bekerjasama dan berkongsi idea.",
                    "<strong>Inisiatif:</strong> Mencari maklumat sendiri.",
                    "<strong>Sahsiah:</strong> Menunjukkan disiplin dan nilai murni."
                ],
                skor4: "Memberi respon, berkomunikasi dan melaksanakan aktiviti secara kolaboratif.",
                questions: [
                    { q: "Ciri murid aktif...", o: ["Diam", "Respon & Tanya", "Tunggu arahan", "Salin nota"], c: 1, d: "Mudah" },
                    { q: "Komunikasi 4.6 ialah...", o: ["Kosong", "Isi pelajaran", "Guru saja cakap", "Isyarat"], c: 1, d: "Mudah" },
                    { q: "Kolaborasi bermaksud...", o: ["Gaduh", "Kerjasama tugasan", "Saing tak sihat", "Duduk asing"], c: 1, d: "Mudah" },
                    { q: "Sifat ingin tahu dilihat bila...", o: ["Tidur", "Tanya Kenapa/Bagaimana", "Jawab Ya/Tidak", "Tiru buku"], c: 1, d: "Mudah" },
                    { q: "Nilai murni termasuk...", o: ["Hormat pendapat", "Curi pembaris", "Kasar", "Sampah lantai"], c: 0, d: "Mudah" },
                    { q: "Pembelajaran kendiri ialah...", o: ["Tanpa guru", "Tanggungjawab sendiri", "Rumah saja", "Tak ikut guru"], c: 1, d: "Sederhana" },
                    { q: "Kreativiti murid...", o: ["Solusi unik", "Lukis buku teks", "Tukar tajuk", "Baju warna"], c: 0, d: "Sederhana" },
                    { q: "Kepimpinan kumpulan dilihat bila...", o: ["Bagi tugas & bantu", "Buat sendiri", "Sorang buat semua", "Main-main"], c: 0, d: "Sederhana" },
                    { q: "Refleksi membantu murid...", o: ["Lupa belajar", "Nilai tahap faham", "Waktu balik", "Nilai guru"], c: 1, d: "Sukar" },
                    { q: "Hubungan 4.4.1 & 4.6...", o: ["Simbiosis", "Tiada kaitan", "Guru buat kerja", "Murid ajar guru"], c: 0, d: "Sukar" }
                ]
            }
        };

        const motivationalQuotes = [
            "Guru adalah pelita yang tidak pernah padam.",
            "Kecemerlangan PdPc anda adalah sinar kejayaan murid.",
            "Mengajar adalah menyalakan api inspirasi.",
            "Standard 4 adalah peta jalan profesionalisme.",
            "Teruslah berkarya untuk amal jariah yang berterusan."
        ];

        let state = {
            currentAspekt: null,
            mode: 'note',
            currentQuestionIdx: 0,
            quizQuestions: []
        };

        function loadAspect(id) {
            state.currentAspekt = id;
            state.mode = 'note';
            
            document.querySelectorAll('.nav-btn').forEach(btn => {
                if(btn.innerText.includes(id)) {
                    btn.classList.add('bg-indigo-100', 'text-indigo-700', 'border-b-2', 'border-indigo-700');
                    btn.classList.remove('hover:bg-slate-100');
                } else {
                    btn.classList.remove('bg-indigo-100', 'text-indigo-700', 'border-b-2', 'border-indigo-700');
                    btn.classList.add('hover:bg-slate-100');
                }
            });

            const data = skpmData[id];
            let noteHtml = `
                <div class="animate-in fade-in slide-in-from-bottom-4 duration-500">
                    <div class="flex items-center space-x-3 mb-4">
                        <span class="bg-indigo-700 text-white px-3 py-1 rounded-md font-bold">${id}</span>
                        <h2 class="text-3xl font-bold text-slate-800">${data.title.split(':')[1]}</h2>
                    </div>
                    
                    <div class="bg-indigo-50 border-l-4 border-indigo-600 p-6 rounded-r-lg mb-8">
                        <h3 class="text-indigo-800 font-bold uppercase text-sm tracking-wider mb-2">Standard Kualiti</h3>
                        <p class="text-slate-700 text-lg leading-relaxed italic">"${data.standard}"</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                        <div>
                            <h3 class="text-slate-800 font-bold mb-4 flex items-center">
                                <svg class="w-5 h-5 mr-2 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                Fokus Tindakan Guru
                            </h3>
                            <ul class="prose-list text-slate-600 space-y-4">
                                ${data.notes.map(note => `<li>${note}</li>`).join('')}
                            </ul>
                        </div>
                        <div class="bg-slate-50 p-6 rounded-xl border border-slate-200">
                            <h3 class="text-emerald-700 font-bold mb-4 flex items-center">
                                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                Syarat Skor 4 (Cemerlang)
                            </h3>
                            <p class="text-slate-600 leading-relaxed text-sm">${data.skor4}</p>
                            <div class="mt-6 p-4 bg-white rounded border border-emerald-100 text-xs text-slate-500">
                                <strong>Nota:</strong> Skor 4 jika menyeluruh, berterusan, dan mengikut keperluan murid.
                            </div>
                        </div>
                    </div>
                </div>
            `;

            document.getElementById('note-content').innerHTML = noteHtml;
            document.getElementById('quiz-btn-container').classList.remove('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function startQuiz() {
            state.mode = 'quiz';
            state.currentQuestionIdx = 0;
            state.quizQuestions = [...skpmData[state.currentAspekt].questions];
            
            document.getElementById('note-view').classList.add('hidden');
            document.getElementById('main-nav').classList.add('hidden');
            document.getElementById('quiz-status').classList.remove('hidden');
            document.getElementById('current-quiz-label').innerText = state.currentAspekt;
            
            document.getElementById('quiz-view').classList.remove('hidden');
            renderQuestion();
        }

        function renderQuestion() {
            const q = state.quizQuestions[state.currentQuestionIdx];
            document.getElementById('question-number').innerText = `Soalan ${state.currentQuestionIdx + 1} / 10`;
            document.getElementById('question-text').innerText = q.q;
            
            const badge = document.getElementById('difficulty-badge');
            badge.innerText = q.d;
            if(q.d === 'Mudah') badge.className = "px-3 py-1 bg-emerald-500 text-xs rounded-full uppercase font-bold";
            else if(q.d === 'Sederhana') badge.className = "px-3 py-1 bg-amber-500 text-xs rounded-full uppercase font-bold";
            else badge.className = "px-3 py-1 bg-rose-500 text-xs rounded-full uppercase font-bold";

            const optionsContainer = document.getElementById('options-container');
            optionsContainer.innerHTML = '';
            
            q.o.forEach((opt, idx) => {
                const btn = document.createElement('button');
                btn.className = "w-full text-left p-4 border-2 border-slate-200 rounded-xl hover:border-indigo-500 hover:bg-indigo-50 transition font-medium flex justify-between items-center group active:bg-indigo-100";
                btn.innerHTML = `<span>${opt}</span><span class="opacity-0 group-hover:opacity-100 text-indigo-500 text-sm">Pilih &raquo;</span>`;
                btn.onclick = () => checkAnswer(idx);
                optionsContainer.appendChild(btn);
            });

            document.getElementById('feedback-message').classList.add('hidden');
        }

        function checkAnswer(idx) {
            const q = state.quizQuestions[state.currentQuestionIdx];
            const feedback = document.getElementById('feedback-message');
            
            if(idx === q.c) {
                feedback.innerText = "TEPAT! Teruskan.";
                feedback.className = "mt-6 p-4 rounded-lg text-center font-bold bg-emerald-100 text-emerald-800 animate-pulse";
                feedback.classList.remove('hidden');
                
                setTimeout(() => {
                    state.currentQuestionIdx++;
                    if(state.currentQuestionIdx < 10) {
                        renderQuestion();
                    } else {
                        showCongrats();
                    }
                }, 800);
            } else {
                feedback.innerText = "KURANG TEPAT. Cuba lagi!";
                feedback.className = "mt-6 p-4 rounded-lg text-center font-bold bg-rose-100 text-rose-800";
                feedback.classList.remove('hidden');
                
                const quizBox = document.querySelector('#quiz-view > div');
                quizBox.classList.add('shake-animation');
                setTimeout(() => quizBox.classList.remove('shake-animation'), 500);
            }
        }

        function showCongrats() {
            state.mode = 'congrats';
            document.getElementById('quiz-view').classList.add('hidden');
            document.getElementById('congrats-view').classList.remove('hidden');
            const randomQuote = motivationalQuotes[Math.floor(Math.random() * motivationalQuotes.length)];
            document.getElementById('motivational-quote').innerText = randomQuote;
        }

        function exitQuiz() {
            document.getElementById('congrats-view').classList.add('hidden');
            document.getElementById('quiz-status').classList.add('hidden');
            document.getElementById('main-nav').classList.remove('hidden');
            document.getElementById('note-view').classList.remove('hidden');
            loadAspect(state.currentAspekt);
        }
    </script>
</body>
</html>
