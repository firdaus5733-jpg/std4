                    "<strong>Keyakinan Diri:</strong> Membimbing murid untuk berani tampil ke hadapan tanpa rasa takut diketawakan.",
                    "<strong>Mendengar Aktif:</strong> Memberi perhatian penuh apabila murid bercakap atau menyatakan pandangan.",
                    "<strong>Sikap Adil:</strong> Memberi galakan kepada semua murid tanpa pilih kasih (inclusivity)."
                ],
                skor4: "Memberi pujian/galakan terhadap usaha dan hasil kerja murid, memberi keyakinan dalam mengemukakan soalan/memberi respon serta menunjukkan prihatin terhadap keperluan murid secara berhemah, menyeluruh dan berterusan.",
                questions: [
                    { q: "Mengapa pujian penting dalam PdP?", o: ["Untuk membazir masa", "Meningkatkan motivasi dan harga diri murid", "Supaya murid puji guru balik", "Syarat untuk lulus SKPM"], c: 1, d: "Mudah" },
                    { q: "Guru menunjukkan prihatin dengan cara...", o: ["Mengabaikan murid yang sedih", "Bertanya khabar dan memberi sokongan moral", "Memberi kerja sekolah yang banyak", "Menghantar ke bilik disiplin"], c: 1, d: "Mudah" },
                    { q: "Sikap adil dalam memberi galakan bermaksud...", o: ["Hanya puji murid pandai", "Hanya puji murid yang kita suka", "Memberi galakan kepada semua murid tanpa mengira tahap", "Tidak puji sesiapa pun"], c: 2, d: "Mudah" },
                    { q: "Bagaimana guru membina keyakinan murid untuk bertanya?", o: ["Wujudkan suasana selamat di mana salah itu tidak dihukum", "Ketawakan jawapan yang salah", "Jangan beri peluang bertanya", "Paksa mereka berdiri sehingga tahu"], c: 0, d: "Mudah" },
                    { q: "Contoh peneguhan positif non-verbal ialah...", o: ["Menjerit 'Syabas'", "Memberi isyarat bagus (thumbs up) atau senyuman", "Menulis nota panjang", "Mendiamkan diri"], c: 1, d: "Mudah" },
                    { q: "Pendorong emosi perlu dilakukan secara...", o: ["Sekali-sekala", "Berterusan sepanjang sesi PdP", "Hanya di akhir kelas", "Hanya waktu perhimpunan"], c: 1, d: "Sederhana" },
                    { q: "Maksud 'berhemah' dalam aspek 4.4.2 ialah...", o: ["Memberi pujian secara berlebihan", "Memberi teguran atau pujian dengan bahasa yang sopan dan menjaga maruah", "Memberi wang kepada murid", "Bersikap garang"], c: 1, d: "Sederhana" },
                    { q: "Bagaimana guru menangani murid yang merasa rendah diri?", o: ["Bandingkan dengan rakan yang lebih hebat", "Fokus pada kekuatan mereka dan beri tanggungjawab kecil", "Biarkan mereka duduk di belakang", "Suruh mereka belajar sendiri"], c: 1, d: "Sederhana" },
                    { q: "Kesan jangka panjang pendorong emosi yang baik ialah...", o: ["Murid jadi manja", "Terbentuknya 'Growth Mindset' dan minat belajar yang tinggi", "Murid tidak takut lagi pada guru", "Markah ujian automatik 100% tanpa belajar"], c: 1, d: "Sukar" },
                    { q: "Kegagalan guru dalam aspek 4.4.2 boleh menyebabkan murid...", o: ["Menjadi terlalu berani", "Hilang minat belajar dan rasa tertekan (anxiety) di dalam kelas", "Sentiasa ingin datang ke sekolah", "Menghormati guru secara ikhlas"], c: 1, d: "Sukar" }
                ]
            },
            "4.5": {
                title: "Aspek 4.5: Guru Sebagai Penilai",
                description: "Guru melaksanakan pentaksiran secara berterusan untuk mengesan tahap penguasaan murid.",
                standard: "Menggunakan pelbagai kaedah pentaksiran, memberi maklum balas serta menyemak hasil kerja murid berdasarkan objektif pembelajaran.",
                notes: [
                    "<strong>Kepelbagaian Kaedah:</strong> Menggunakan pentaksiran lisan (kuiz, soal-jawab), bertulis (latihan, ujian), dan pemerhatian (kemahiran, sikap).",
                    "<strong>Maklum Balas Segera:</strong> Memberi komen yang membina (bukan hanya tanda ✔️) supaya murid tahu kesalahan mereka serta merta.",
                    "<strong>Semakan Hasil Kerja:</strong> Menyemak buku atau tugasan secara tekal dan teliti mengikut kriteria.",
                    "<strong>Pemulihan & Pengayaan:</strong> Menggunakan data penilaian untuk merancang aktiviti susulan (yang belum faham dibantu, yang sudah faham dicabar lagi).",
                    "<strong>Penilaian Kendiri/Rakan:</strong> Melibatkan murid dalam menilai kerja sendiri atau rakan (self/peer assessment)."
                ],
                skor4: "Menggunakan pelbagai kaedah pentaksiran dalam PdP, memberi maklum balas bagi pembetulan/penambahbaikan segera, menyemak hasil kerja murid serta menjalankan aktiviti pemulihan/pengayaan mengikut keperluan, secara menyeluruh dan berterusan.",
                questions: [
                    { q: "Pentaksiran Bilik Darjah (PBD) dalam aspek 4.5 perlu dilakukan secara...", o: ["Sekali setahun", "Berterusan sepanjang PdP", "Hanya waktu peperiksaan", "Jika ada pemantauan sahaja"], c: 1, d: "Mudah" },
                    { q: "Antara kaedah pentaksiran dalam PdP ialah...", o: ["Lisan, Bertulis dan Pemerhatian", "Membaca komik", "Hanya ujian bulanan", "Menonton wayang"], c: 0, d: "Mudah" },
                    { q: "Maklum balas guru perlulah...", o: ["Negatif dan menghina", "Membina untuk penambahbaikan", "Dalam bahasa asing", "Diberi selepas sebulan"], c: 1, d: "Mudah" },
                    { q: "Hasil kerja murid perlu disemak untuk...", o: ["Mengisi masa guru", "Mengesan tahap penguasaan dan kesalahan murid", "Tunjukkan pada pengetua sahaja", "Dibuang selepas habis subjek"], c: 1, d: "Mudah" },
                    { q: "Aktiviti pengayaan diberikan kepada murid yang...", o: ["Sangat lemah", "Telah mencapai objektif dan perlu cabaran tambahan", "Suka tidur", "Selalu ponteng"], c: 1, d: "Mudah" },
                    { q: "Apakah beza maklum balas 'evaluatif' dan 'deskriptif'?", o: ["Tiada beza", "Evaluatif hanya beri gred, Deskriptif beri cara baiki jawapan", "Evaluatif lebih baik", "Deskriptif hanya untuk subjek Bahasa"], c: 1, d: "Sederhana" },
                    { q: "Bagaimana guru menjalankan pemulihan dalam PdP?", o: ["Memberi latihan yang sama berulang kali", "Mengubah strategi atau menggunakan bahan lebih mudah bagi murid yang belum faham", "Menghukum murid yang lambat", "Mengeluarkan mereka dari kelas"], c: 1, d: "Sederhana" },
                    { q: "Penilaian rakan (peer assessment) membantu murid untuk...", o: ["Mencari salah kawan", "Membangunkan kemahiran berfikir kritikal dan objektif", "Bercakap-cakap dalam kelas", "Meniru jawapan"], c: 1, d: "Sederhana" },
                    { q: "Penggunaan 'Exit Ticket' di akhir kelas adalah contoh pentaksiran...", o: ["Formatif (untuk penambahbaikan)", "Sumatif (untuk gred akhir)", "Diagnostik (untuk sakit)", "Tiada kaitan"], c: 0, d: "Sukar" },
                    { q: "Data pentaksiran dalam 4.5 seharusnya digunakan oleh guru untuk...", o: ["Mencari kesalahan murid", "Merancang tindakan susulan dan modifikasi PdP akan datang", "Melabel murid pandai dan bodoh", "Menunjuk-nunjuk kepada rakan sejawat"], c: 1, d: "Sukar" }
                ]
            },
            "4.6": {
                title: "Aspek 4.6: Murid Sebagai Pembelajar Aktif",
                description: "Murid terlibat secara aktif dalam pembelajaran, berkolaborasi, dan berkomunikasi serta mengamalkan nilai murni.",
                standard: "Murid terlibat dalam proses pembelajaran secara aktif, menunjukkan minat dan semangat ingin tahu serta bertanggungjawab terhadap pembelajaran.",
                notes: [
                    "<strong>Respons Murid:</strong> Murid menjawab soalan, bertanya, dan memberi pendapat secara spontan atau terancang.",
                    "<strong>Kerjasama Pasukan:</strong> Murid bekerjasama dalam kumpulan, berkongsi idea, dan saling membantu (kolaborasi).",
                    "<strong>Inisiatif & Inkuiri:</strong> Murid mencari maklumat tambahan sendiri dan menunjukkan rasa ingin tahu yang tinggi.",
                    "<strong>Kepimpinan & Sahsiah:</strong> Murid menunjukkan nilai murni, disiplin kendiri, dan menghormati pandangan orang lain.",
                    "<strong>Refleksi Kendiri:</strong> Murid sedar apa yang mereka pelajari dan apa yang mereka belum kuasai."
                ],
                skor4: "Memberi respon berkaitan isi pelajaran, berkomunikasi dalam melaksanakan aktiviti pembelajaran, melaksanakan aktiviti pembelajaran secara kolaboratif serta menunjukkan kreativiti/sifat ingin tahu dan mengamalkan nilai murni.",
                questions: [
                    { q: "Apakah ciri utama murid sebagai pembelajar aktif?", o: ["Diam dan mendengar sahaja", "Terlibat aktif, memberi respon dan bertanya", "Menunggu arahan guru 100%", "Menyalin nota dari papan hitam"], c: 1, d: "Mudah" },
                    { q: "Komunikasi dalam 4.6 merujuk kepada...", o: ["Bercakap kosong dengan kawan", "Perbincangan berkaitan isi pelajaran", "Guru sahaja yang bercakap", "Menggunakan isyarat tangan"], c: 1, d: "Mudah" },
                    { q: "Kolaborasi murid bermaksud mereka...", o: ["Bergaduh dalam kumpulan", "Bekerjasama menyelesaikan tugasan", "Bersaing secara tidak sihat", "Duduk berasingan"], c: 1, d: "Mudah" },
                    { q: "Sifat ingin tahu (curiosity) ditunjukkan apabila murid...", o: ["Tidur dalam kelas", "Mengemukakan soalan 'Kenapa' dan 'Bagaimana'", "Hanya menjawab 'Ya' atau 'Tidak'", "Meniru jawapan buku"], c: 1, d: "Mudah" },
                    { q: "Mengamalkan nilai murni di kelas termasuk...", o: ["Menghormati pendapat rakan", "Mencuri pembaris kawan", "Bercakap kasar dengan guru", "Membuang sampah di lantai"], c: 0, d: "Mudah" },
                    { q: "Pembelajaran kendiri (self-directed learning) bermaksud murid...", o: ["Belajar tanpa guru selamanya", "Mempunyai inisiatif mencari ilmu dan bertanggungjawab atas kemajuan sendiri", "Hanya belajar di rumah", "Tidak mahu mendengar arahan guru"], c: 1, d: "Sederhana" },
                    { q: "Bagaimana murid menunjukkan kreativiti dalam 4.6?", o: ["Menghasilkan karya atau solusi unik bagi tugasan", "Melukis di dalam buku teks", "Menukar tajuk pelajaran", "Memakai baju berwarna-warni"], c: 0, d: "Sederhana" },
                    { q: "Kepimpinan murid dalam kumpulan dapat dilihat apabila...", o: ["Seorang murid membahagikan tugas dan membantu rakan lain", "Semua murid buat kerja sendiri", "Seorang murid buat semua kerja", "Murid bermain-main"], c: 0, d: "Sederhana" },
                    { q: "Refleksi murid di akhir kelas membantu mereka untuk...", o: ["Lupakan apa yang belajar", "Menilai tahap kefahaman sendiri dan menetapkan matlamat seterusnya", "Mengetahui waktu balik", "Menilai kelemahan guru sahaja"], c: 1, d: "Sukar" },
                    { q: "Hubungan antara 4.4.1 (Guru) dan 4.6 (Murid) adalah...", o: ["Simbiosis - Guru merangsang, murid bertindak balas aktif", "Tiada kaitan langsung", "Guru buat kerja, murid tengok sahaja", "Murid mengajar guru"], c: 0, d: "Sukar" }
                ]
            }
        };

        const motivationalQuotes = [
            "Guru adalah pelita yang tidak pernah padam dalam membina peradaban manusia.",
            "Kecemerlangan PdPc anda hari ini adalah sinar kejayaan murid anda di masa hadapan.",
            "Mengajar bukan sekadar mengisi botol, tetapi menyalakan api inspirasi.",
            "Standard 4 bukan beban, tetapi peta jalan ke arah profesionalisme keguruan yang hakiki.",
            "Teruslah berkarya, kerana setiap usaha anda dicatat sebagai amal jariah yang tiada penghujung."
        ];

        let state = {
            currentAspekt: null,
            mode: 'note',
            currentQuestionIdx: 0,
            quizQuestions: []
        };

        function loadAspect(id) {
            state.currentAspekt = id;
            state.mode = 'note';
            
            // Update UI Nav
            document.querySelectorAll('.nav-btn').forEach(btn => {
                if(btn.innerText.includes(id)) {
                    btn.classList.add('bg-indigo-100', 'text-indigo-700', 'border-b-2', 'border-indigo-700');
                    btn.classList.remove('hover:bg-slate-100');
                } else {
                    btn.classList.remove('bg-indigo-100', 'text-indigo-700', 'border-b-2', 'border-indigo-700');
                    btn.classList.add('hover:bg-slate-100');
                }
            });

            const data = skpmData[id];
            let noteHtml = `
                <div class="animate-in fade-in slide-in-from-bottom-4 duration-500">
                    <div class="flex items-center space-x-3 mb-4">
                        <span class="bg-indigo-700 text-white px-3 py-1 rounded-md font-bold">${id}</span>
                        <h2 class="text-3xl font-bold text-slate-800">${data.title.split(':')[1]}</h2>
                    </div>
                    
                    <div class="bg-indigo-50 border-l-4 border-indigo-600 p-6 rounded-r-lg mb-8">
                        <h3 class="text-indigo-800 font-bold uppercase text-sm tracking-wider mb-2">Standard Kualiti</h3>
                        <p class="text-slate-700 text-lg leading-relaxed italic">"${data.standard}"</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                        <div>
                            <h3 class="text-slate-800 font-bold mb-4 flex items-center">
                                <svg class="w-5 h-5 mr-2 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                Fokus Tindakan Guru
                            </h3>
                            <ul class="prose-list text-slate-600 space-y-4">
                                ${data.notes.map(note => `<li>${note}</li>`).join('')}
                            </ul>
                        </div>
                        <div class="bg-slate-50 p-6 rounded-xl border border-slate-200">
                            <h3 class="text-emerald-700 font-bold mb-4 flex items-center">
                                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                Syarat Skor 4 (Cemerlang)
                            </h3>
                            <p class="text-slate-600 leading-relaxed text-sm">
                                ${data.skor4}
                            </p>
                            <div class="mt-6 p-4 bg-white rounded border border-emerald-100 text-xs text-slate-500">
                                <strong>Nota Penilai:</strong> Skor 4 diberikan jika tindakan dilaksanakan dengan mematuhi ketetapan, secara menyeluruh, berterusan, dan mengikut keperluan murid.
                            </div>
                        </div>
                    </div>
                </div>
            `;

            document.getElementById('note-content').innerHTML = noteHtml;
            document.getElementById('quiz-btn-container').classList.remove('hidden');
            
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function startQuiz() {
            state.mode = 'quiz';
            state.currentQuestionIdx = 0;
            state.quizQuestions = [...skpmData[state.currentAspekt].questions];
            
            document.getElementById('note-view').classList.add('hidden');
            document.getElementById('main-nav').classList.add('hidden');
            document.getElementById('quiz-status').classList.remove('hidden');
            document.getElementById('current-quiz-label').innerText = state.currentAspekt;
            
            document.getElementById('quiz-view').classList.remove('hidden');
            renderQuestion();
        }

        function renderQuestion() {
            const q = state.quizQuestions[state.currentQuestionIdx];
            document.getElementById('question-number').innerText = `Soalan ${state.currentQuestionIdx + 1} / 10`;
            document.getElementById('question-text').innerText = q.q;
            
            const badge = document.getElementById('difficulty-badge');
            badge.innerText = q.d;
            if(q.d === 'Mudah') badge.className = "px-3 py-1 bg-emerald-500 text-xs rounded-full uppercase font-bold";
            else if(q.d === 'Sederhana') badge.className = "px-3 py-1 bg-amber-500 text-xs rounded-full uppercase font-bold";
            else badge.className = "px-3 py-1 bg-rose-500 text-xs rounded-full uppercase font-bold";

            const optionsContainer = document.getElementById('options-container');
            optionsContainer.innerHTML = '';
            
            q.o.forEach((opt, idx) => {
                const btn = document.createElement('button');
                btn.className = "w-full text-left p-4 border-2 border-slate-200 rounded-xl hover:border-indigo-500 hover:bg-indigo-50 transition font-medium flex justify-between items-center group active:bg-indigo-100";
                btn.innerHTML = `
                    <span>${opt}</span>
                    <span class="opacity-0 group-hover:opacity-100 text-indigo-500 text-sm">Pilih &raquo;</span>
                `;
                btn.onclick = () => checkAnswer(idx);
                optionsContainer.appendChild(btn);
            });

            document.getElementById('feedback-message').classList.add('hidden');
        }

        function checkAnswer(idx) {
            const q = state.quizQuestions[state.currentQuestionIdx];
            const feedback = document.getElementById('feedback-message');
            
            if(idx === q.c) {
                feedback.innerText = "TEPAT! Teruskan ke soalan seterusnya.";
                feedback.className = "mt-6 p-4 rounded-lg text-center font-bold bg-emerald-100 text-emerald-800 animate-pulse";
                feedback.classList.remove('hidden');
                
                setTimeout(() => {
                    state.currentQuestionIdx++;
                    if(state.currentQuestionIdx < 10) {
                        renderQuestion();
                    } else {
                        showCongrats();
                    }
                }, 800);
            } else {
                feedback.innerText = "KURANG TEPAT. Cuba fikirkan semula berdasarkan nota tadi.";
                feedback.className = "mt-6 p-4 rounded-lg text-center font-bold bg-rose-100 text-rose-800";
                feedback.classList.remove('hidden');
                
                const quizBox = document.querySelector('#quiz-view > div');
                quizBox.classList.add('animate-bounce');
                setTimeout(() => quizBox.classList.remove('animate-bounce'), 500);
            }
        }

        function showCongrats() {
            state.mode = 'congrats';
            document.getElementById('quiz-view').classList.add('hidden');
            document.getElementById('congrats-view').classList.remove('hidden');
            
            const randomQuote = motivationalQuotes[Math.floor(Math.random() * motivationalQuotes.length)];
            document.getElementById('motivational-quote').innerText = randomQuote;
        }

        function exitQuiz() {
            document.getElementById('congrats-view').classList.add('hidden');
            document.getElementById('quiz-status').classList.add('hidden');
            document.getElementById('main-nav').classList.remove('hidden');
            document.getElementById('note-view').classList.remove('hidden');
            loadAspect(state.currentAspekt);
        }
    </script>
</body>
</html>
