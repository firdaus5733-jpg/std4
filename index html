                    { q: "Soalan mencapah (open-ended) penting kerana...", o: ["Mempunyai hanya satu jawapan betul", "Mempunyai pelbagai kemungkinan jawapan dan merangsang imaginasi", "Senang untuk diperiksa", "Boleh dijawab dengan 'Ya' atau 'Tidak'"], c: 1, d: "Sederhana" },
                    { q: "Tindakan guru yang menghargai idea salah murid dengan membetulkannya secara positif menunjukkan...", o: ["Guru pendorong minda dan emosi yang baik", "Guru yang tidak tahu jawapan", "Guru yang membazir masa", "Guru yang lemah"], c: 0, d: "Sukar" },
                    { q: "Pendorong minda yang berkesan menghasilkan murid yang...", o: ["Hafal semua fakta", "Berupaya menganalisis dan menilai maklumat secara kritis", "Hanya mendengar arahan", "Cekap menyalin nota"], c: 1, d: "Sukar" }
                ]
            },
            "4.4.2": {
                title: "Aspek 4.4.2: Guru Sebagai Pendorong Emosi",
                description: "Guru memberi sokongan moral dan pujian untuk membina keyakinan diri dan motivasi murid.",
                standard: "Memberi pujian/galakan terhadap usaha dan hasil kerja murid serta menunjukkan prihatin terhadap keperluan/perasaan murid.",
                notes: [
                    "<strong>Peneguhan Positif:</strong> Memberi pujian verbal, ganjaran non-verbal (senyuman, bintang), atau hadiah kecil atas usaha murid.",
