                    { q: "Penerokaan (exploration) murid bermaksud...", o: ["Murid berjalan di padang", "Murid mencari maklumat atau jawapan melalui inkuiri", "Guru memberi nota lengkap", "Menyalin dari buku teks"], c: 1, d: "Mudah" },
                    { q: "Contoh alat berfikir yang popular dalam sekolah Malaysia ialah...", o: ["Peta I-Think", "Buku teks", "Pembaris", "Kapur tulis"], c: 0, d: "Mudah" },
